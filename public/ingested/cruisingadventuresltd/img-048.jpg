		color: #3525e6;
	}

	.meta-article .ico-action a:hover {
		color: #3525e6;
	}

	.img-article .holder:hover .caption,
	.img-article .holder:hover .text-block {
		background: #3525e6;
	}

	.list-view .article .thumbnail:hover h3 a {
